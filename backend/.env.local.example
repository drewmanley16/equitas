# Local Anvil + MockUSDC only — copy to .env for scripts/run-local-backend.sh
# Never commit backend/.env

RPC_URL=http://127.0.0.1:8545
PORT=3000

# After deploy-local-contracts.sh, scripts fill these:
SNAP_SPENDER_ADDRESS=0x0000000000000000000000000000000000000000
USDC_ADDRESS=0x0000000000000000000000000000000000000000

# OPERATOR_PRIVATE_KEY: inject only scripts/arc-local-constants.sh ANVIL_ACCOUNT_0_PRIVATE_KEY
# (default Anvil account #0 — local disposable, never use off localhost).
OPERATOR_PRIVATE_KEY=
